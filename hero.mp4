<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pineclo — Coming Soon</title>
<meta name="description" content="Pineclo. Made for hikers, by hikers. Coming soon.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Helvetica+Neue:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{ box-sizing:border-box; margin:0; padding:0; }
html,body{ height:100%; overflow:hidden; }
body{
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  background: #071a09;
  color: #fff;
  -webkit-font-smoothing: antialiased;
}

/* ── VIDEO BG ── */
.video-bg{
  position: fixed; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: 62% center;
  z-index: 0;
}

/* ── GRADIENT OVERLAY ── */
.overlay{
  position: fixed; inset: 0; z-index: 1;
  background:
    linear-gradient(
      160deg,
      rgba(4,18,6,0.72) 0%,
      rgba(4,18,6,0.50) 40%,
      rgba(4,18,6,0.38) 70%,
      rgba(4,18,6,0.55) 100%
    );
}

/* ── MAIN LAYOUT ── */
.page{
  position: relative; z-index: 2;
  height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 44px 56px 50px;
}

/* ── TOP: LOGO ── */
.top{
  display: flex;
  align-items: center;
  gap: 12px;
}
.logo-img{
  height: 42px; width: auto;
  animation: float 3.4s ease-in-out infinite;
  filter: drop-shadow(0 6px 14px rgba(0,0,0,0.35));
}
@keyframes float{
  0%,100%{ transform: translateY(0) rotate(0deg); }
  35%{ transform: translateY(-6px) rotate(-1.5deg); }
  68%{ transform: translateY(-2px) rotate(1deg); }
}
.logo-name{
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #fff;
}

/* ── CENTER: MAIN CONTENT ── */
.center{
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
  max-width: 720px;
}

.badge{
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  margin-bottom: 28px;
}
.badge-dot{
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #12a620;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse{
  0%,100%{ opacity:1; transform:scale(1); }
  50%{ opacity:0.5; transform:scale(0.8); }
}

.headline{
  font-size: clamp(3.8rem, 10vw, 8.5rem);
  font-weight: 700;
  line-height: 0.95;
  letter-spacing: -0.04em;
  color: #fff;
  margin-bottom: 30px;
}
.headline em{
  font-style: normal;
  color: #12a620;
}

.tagline{
  font-size: clamp(15px, 2vw, 18px);
  font-weight: 300;
  color: rgba(255,255,255,0.72);
  letter-spacing: 0.01em;
  line-height: 1.6;
  max-width: 46ch;
  margin-bottom: 44px;
}

/* ── EMAIL FORM ── */
.form-label{
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 12px;
  display: block;
}
.form-row{
  display: flex;
  gap: 0;
  max-width: 420px;
  width: 100%;
  border: 1.5px solid rgba(255,255,255,0.3);
  border-radius: 3px;
  overflow: hidden;
  transition: border-color .25s;
}
.form-row:focus-within{ border-color: rgba(255,255,255,0.7); }
.form-row input{
  flex: 1;
  background: rgba(255,255,255,0.08);
  border: none; outline: none;
  padding: 15px 18px;
  font-family: inherit;
  font-size: 14.5px;
  font-weight: 400;
  color: #fff;
  backdrop-filter: blur(4px);
}
.form-row input::placeholder{ color: rgba(255,255,255,0.38); }
.form-row button{
  background: #0b8b1a;
  border: none; cursor: pointer;
  padding: 0 22px;
  font-family: inherit;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #fff;
  transition: background .2s;
  white-space: nowrap;
}
.form-row button:hover{ background: #076913; }
.form-success{
  font-size: 13.5px;
  font-weight: 500;
  color: #12a620;
  letter-spacing: 0.04em;
  margin-top: 14px;
  display: none;
}

/* ── BOTTOM: FOOTER ROW ── */
.bottom{
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.copy{
  font-size: 12px;
  color: rgba(255,255,255,0.38);
  letter-spacing: 0.04em;
}
.socials{
  display: flex;
  gap: 18px;
}
.socials a{
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  transition: color .2s;
}
.socials a:hover{ color: #fff; }

/* ── VERTICAL LINES DECOR ── */
.lines{
  position: fixed; inset: 0; z-index: 1;
  pointer-events: none;
  opacity: 0.06;
}
.lines svg{ width:100%; height:100%; }

/* ── MOBILE ── */
@media (max-width: 600px){
  .page{ padding: 30px 24px 36px; }
  .video-bg{ object-position: 50% 25%; }
  .overlay{
    background: linear-gradient(to top,
      rgba(4,18,6,0.88) 0%,
      rgba(4,18,6,0.55) 40%,
      rgba(4,18,6,0.28) 100%);
  }
  .headline{ letter-spacing: -0.03em; }
  .form-row{ max-width: 100%; }
  .bottom{ flex-direction: column; gap: 16px; }
  .logo-img{ height: 36px; }
  .logo-name{ font-size: 19px; }
}
</style>
</head>
<body>

<!-- VIDEO BACKGROUND -->
<video class="video-bg" autoplay muted loop playsinline preload="auto" aria-hidden="true">
  <source src="hero.mp4" type="video/mp4">
</video>

<!-- GRADIENT -->
<div class="overlay" aria-hidden="true"></div>

<!-- DECORATIVE VERTICAL LINES -->
<div class="lines" aria-hidden="true">
  <svg viewBox="0 0 1440 900" preserveAspectRatio="none">
    <line x1="240" y1="0" x2="240" y2="900" stroke="#fff" stroke-width="1"/>
    <line x1="480" y1="0" x2="480" y2="900" stroke="#fff" stroke-width="1"/>
    <line x1="720" y1="0" x2="720" y2="900" stroke="#fff" stroke-width="1"/>
    <line x1="960" y1="0" x2="960" y2="900" stroke="#fff" stroke-width="1"/>
    <line x1="1200" y1="0" x2="1200" y2="900" stroke="#fff" stroke-width="1"/>
  </svg>
</div>

<!-- PAGE -->
<div class="page">

  <!-- TOP: LOGO -->
  <div class="top">
    <img class="logo-img" src="logo.png" alt="Pineclo logo" width="52" height="42">
    <span class="logo-name">Pineclo.</span>
  </div>

  <!-- CENTER: MAIN CONTENT -->
  <div class="center">
    <div class="badge">
      <span class="badge-dot"></span>
      Something is coming
    </div>

    <h1 class="headline">Almost<br>on the<br><em>trail.</em></h1>

    <p class="tagline">
      Made for hikers, by hikers. We're putting the final stitches in — 
      drop your email and be the first to know when we launch.
    </p>

    <label class="form-label" for="cs-email">Get early access</label>
    <form id="cs-form">
      <div class="form-row">
        <input type="email" id="cs-email" placeholder="you@outdoors.com" required autocomplete="email">
        <button type="submit">Notify me</button>
      </div>
    </form>
    <p class="form-success" id="form-success">You're on the list. See you on the trail. 🌲</p>
  </div>

  <!-- BOTTOM: FOOTER -->
  <div class="bottom">
    <p class="copy">© 2026 Pineclo. All rights reserved.</p>
    <nav class="socials">
      <a href="#">Instagram</a>
      <a href="#">Contact</a>
    </nav>
  </div>

</div>

<script>
document.getElementById('cs-form').addEventListener('submit', function(e) {
  e.preventDefault();
  this.style.display = 'none';
  document.getElementById('form-success').style.display = 'block';
});
</script>

</body>
</html>